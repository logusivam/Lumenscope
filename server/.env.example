# Server Port (default: 3001)
PORT=3001

# Frontend Origin URL for CORS configuration (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Gmail API OAuth2 Credentials for Contact Form Email Routing
EMAIL_USER=your-gmail-address@gmail.com
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
